generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./main.db" 
}

model MediaWikiRecentChange {
  id        Int      @id @default(autoincrement())
  title     String?  
  titleUrl  String? 
  comment   String?
  timestamp DateTime @default(now())
  user      String?
  bot       Boolean?
  notifyUrl String?
  fullEdit  String?
  minor     Boolean?
  lengthOld Int?
  lengthNew Int?
  serverUrl String?
}

model MediaWikiRecentChangeSpike {
  id           Int      @id @default(autoincrement())
  title        String   
  startTime    DateTime
  lastEditTime DateTime
  totalEdits   Int      @default(0)
  totalBytes   Int      @default(0)
  isActive     Boolean  @default(true)
}
